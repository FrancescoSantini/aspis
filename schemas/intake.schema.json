{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASPIS intake row",
  "type": "object",
  "required": ["library_id", "input_1"],
  "properties": {
    "library_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "biospecimen_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "input_1": {
      "type": "string",
      "minLength": 1
    },
    "input_2": {
      "type": "string"
    },
    "assay_hint": {
      "type": "string",
      "enum": ["", "rnaseq", "rna-seq", "rna_seq", "mrna", "mrnaseq", "mrna-seq", "mrna_seq", "longrna", "longrna-seq", "smallrna", "smallrna-seq", "small-rna", "small-rna-seq", "mirna", "mirnaseq", "mirna-seq"]
    },
    "assay": {
      "type": "string",
      "enum": ["", "rnaseq", "rna-seq", "rna_seq", "mrna", "mrnaseq", "mrna-seq", "mrna_seq", "longrna", "longrna-seq", "smallrna", "smallrna-seq", "small-rna", "small-rna-seq", "mirna", "mirnaseq", "mirna-seq"]
    },
    "library_strategy": {
      "type": "string"
    },
    "library_selection": {
      "type": "string"
    },
    "library_layout": {
      "type": "string"
    },
    "library_source": {
      "type": "string"
    },
    "instrument_platform": {
      "type": "string"
    },
    "instrument_model": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "string"
  }
}
