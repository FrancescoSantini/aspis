{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ASPIS materialized manifest row",
  "type": "object",
  "required": ["library_id", "source_type", "layout", "fastq_1"],
  "properties": {
    "library_id": {
      "type": "string"
    },
    "biospecimen_id": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": ["local_fastq", "insdc_run"]
    },
    "source_id": {
      "type": "string"
    },
    "archive": {
      "type": "string"
    },
    "public_metadata_source": {
      "type": "string"
    },
    "public_metadata_status": {
      "type": "string",
      "enum": ["not_applicable", "resolved", "failed"]
    },
    "public_metadata_error": {
      "type": "string"
    },
    "run_accession": {
      "type": "string"
    },
    "experiment_accession": {
      "type": "string"
    },
    "sample_accession": {
      "type": "string"
    },
    "study_accession": {
      "type": "string"
    },
    "library_layout": {
      "type": "string"
    },
    "library_strategy": {
      "type": "string"
    },
    "library_source": {
      "type": "string"
    },
    "library_selection": {
      "type": "string"
    },
    "assay": {
      "type": "string"
    },
    "assay_confidence": {
      "type": "string",
      "enum": ["user_hint", "metadata", "ambiguous_metadata", "unclassified"]
    },
    "assay_reason": {
      "type": "string"
    },
    "layout": {
      "type": "string",
      "enum": ["single", "paired"]
    },
    "fastq_1": {
      "type": "string"
    },
    "fastq_2": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "type": "string"
  }
}
