import re
import pandas as pd

configfile: "config/config.yaml"

# Load sample data 
df = pd.read_table('config/sample_sheet.csv', sep=',').set_index('sample_name', drop=False)

wildcard_constraints:
    bioproject="\w+",
    accession="\w+"

# Function to check if a sample is coming from SRA
def check_sample(accession, bioproject):
    pattern = r"^(SRR|ERR|DRR)[0-9]+$"
    if re.match(pattern, accession):
        return f"samples/{bioproject}/{accession}/{accession}.sra"

# List of SRA sample paths
sra_samples = [
    check_sample(row['run'], row['bioproject'])
    for _, row in df.iterrows()
    if check_sample(row['run'], row['bioproject']) is not None
]
    
rule all:
    input:
        sra_samples

rule prefetch_sra_sample:
    output:
        "samples/{bioproject}/{accession}/{accession}.sra"
    threads: 1
    resources:
##        partition="g100_all_serial",
        mem_mb=7800,
        time="04:00:00"
    shell:
        """
        prefetch -X 40G -p -o {output} {wildcards.accession}
        echo "Downloaded data for sample {wildcards.accession} from SRA."
