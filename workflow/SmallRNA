rule download_mirbase_fasta:
    output:
        fasta="genome/mirbase.fa"
    resources:
        mem_mb=100
    shell:
        """
        wget -O genome/mature.fa https://www.mirbase.org/download/mature.fa
        wget -O genome/hairpin.fa https://www.mirbase.org/download/hairpin.fa
        awk '/^>hsa/ {{print; getline; print}}' genome/mature.fa > genome/mature_hsa.fa
        awk '/^>hsa/ {{print; getline; print}}' genome/hairpin.fa > genome/hairpin_hsa.fa
        cat genome/mature_hsa.fa genome/hairpin_hsa.fa | \
        awk '{{ if ($0 ~ /^>/) print; else {{ gsub(/U/, "T"); print }} }}' > {output.fasta}
        """

rule fasta_to_saf:
    input:
        fasta="genome/mirbase.fa"
    output:
        saf="genome/mirbase.saf"
    resources:
        mem_mb=500
    run:
        with open(input.fasta) as fin, open(output.saf, "w") as fout:
            fout.write("GeneID\tChr\tStart\tEnd\tStrand\n")
            gene_id = None
            seq = []
            for line in fin:
                if line.startswith(">"):
                    if gene_id:
                        fout.write(f"{gene_id}\t{gene_id}\t1\t{len(''.join(seq))}\t+\n")
                    gene_id = line[1:].split()[0]
                    seq = []
                else:
                    seq.append(line.strip())
            if gene_id:
                fout.write(f"{gene_id}\t{gene_id}\t1\t{len(''.join(seq))}\t+\n")

rule bowtie_build:
    input:
        fasta = rules.download_mirbase_fasta.output.fasta
    output:
        index = directory("genome/bowtie_index")
    threads: 4
    resources:
        mem_mb=4000
    log:
        "logs/bowtie_build.log"
    shell:
        """
        mkdir -p {output.index}
        bowtie-build {input.fasta} {output.index}/mirbase > {log} 2>&1
        """

rule download_contaminants:
    output:
        "genome/contaminants_dna.fa"
    shell:
        """
        wget --no-check-certificate -O genome/human_tRNA.fa https://gtrnadb.ucsc.edu/genomes/eukaryota/Hsapi19/hg19-mature-tRNAs.fa
        wget -O genome/rRNA_SSU.fa.gz https://www.arb-silva.de/fileadmin/silva_databases/current/Exports/SILVA_138.2_SSURef_NR99_tax_silva_trunc.fasta.gz
        wget -O genome/rRNA_LSU.fa.gz https://www.arb-silva.de/fileadmin/silva_databases/current/Exports/SILVA_138.2_LSURef_NR99_tax_silva_trunc.fasta.gz
        gunzip -c genome/rRNA_SSU.fa.gz | awk '/^>.*Homo sapiens/ {{print; getline; print}}' > genome/rRNA_SSU.fa
        gunzip -c genome/rRNA_LSU.fa.gz | awk '/^>.*Homo sapiens/ {{print; getline; print}}' > genome/rRNA_LSU.fa
        cat genome/human_tRNA.fa genome/rRNA_SSU.fa genome/rRNA_LSU.fa > genome/contaminants.fa
         awk '/^>/ {{ print; next }} {{ gsub(/U/, "T"); print }}' genome/contaminants.fa > {output}
        """

rule build_contaminant_index:
    input:
        "genome/contaminants_dna.fa"
    output:
        index=directory("genome/contaminants_index")
    threads: 4
    log: "logs/bowtie_contaminants_build.log"
    shell:
        """
        mkdir -p {output.index}
        bowtie-build {input} {output.index}/contaminants > {log} 2>&1
        """

rule fastqc_pre:
    input:
        "samples/{bioproject}/{run}/{run}_short.fq.gz"
    output:
        html="results/qc/fastqc_pre/{bioproject}/{run}/{run}_short_fastqc.html",
        zip="results/qc/fastqc_pre/{bioproject}/{run}/{run}_short_fastqc.zip"
    log:
        "logs/fastqc_pre/{bioproject}/{run}_short.log"
    threads: 2
    resources:
        mem_mb=2000
    shell:
        """
        fastqc -o results/qc/fastqc_pre/{wildcards.bioproject}/{wildcards.run} {input} > {log} 2>&1
        """

rule cutadapt:
    input:
        "samples/{bioproject}/{run}/{run}_short.fq.gz"
    output:
        trimmed="results/trimmed/{bioproject}/{run}/{run}_short_trimmed.fq.gz",
        summary="logs/cutadapt/{bioproject}/{run}_short_summary.json"
    log:
        "logs/cutadapt/{bioproject}/{run}_short.log"
    threads: 2
    resources:
        mem_mb=2000
    params:
        adapter="AGATCGGAAGAGCACACGTCTGAACTCC"
    shell:
        """
        cutadapt \
            -a {params.adapter} --overlap 5 --quality-cutoff 20 -m 16 -M 50 --match-read-wildcards --trim-n --report=full \
            --json {output.summary} -o {output.trimmed} {input} > {log} 2>&1
        """

