# Snakefile: smallRNA-seq pipeline (mature miRNA quantification, human, 50nt reads)

configfile: "config/config.yaml"

import os
import pandas as pd

# Load sample sheet and filter for smallRNA entries
df = pd.read_csv("config/sample_sheet.csv").set_index("sample_name", drop=False)
df = df[df["bioproject"].str.endswith("_short")]

# Adjust pandas display options
pd.set_option('display.max_rows', None)  # Show all rows
pd.set_option('display.max_columns', None)  # Show all columns
pd.set_option('display.width', 1000)  # Adjust the width of the display
pd.set_option('display.colheader_justify', 'center')  # Adjust column header alignment

print(df)

# Extract unique samples
SAMPLES = df["sample_name"].tolist()
BIOPROJECTS = df["bioproject"].unique().tolist()

# Map each sample to its metadata
sample_info = {
    row["sample_name"]: {
        "run": row["run"],
        "bioproject": row["bioproject"]
    }
    for _, row in df.iterrows()
}

# Write filtered metadata for DESeq2
os.makedirs("results/deg", exist_ok=True)
for bp in BIOPROJECTS:
    os.makedirs(f"results/deg/{bp}", exist_ok=True)
    df_filtered = df[df.bioproject == bp].copy()
    phenodata = df_filtered[["sample_name", "biosample", "condition"] +
                            [col for col in df.columns if col.startswith("covariate")]] \
                .set_index("sample_name") \
                .fillna("NA")

    phenodata.to_csv(f"results/deg/{bp}/phenodata.csv", sep=",")

# Create triple list for DESeq2 contrasts (bioproject, condition != control, covariate1)
bioproject_condition_covariate_triples = []
for bp in BIOPROJECTS:
    subdf = df[df["bioproject"] == bp]
    conditions = subdf["condition"].dropna().unique().tolist()
    conditions = [c for c in conditions if c != "control"]
    covariates = subdf["covariate1"].dropna().unique().tolist()

    for condition in conditions:
        for covariate in covariates:
            bioproject_condition_covariate_triples.append((bp, condition, covariate))

# Define zipped components for use in expand() in rule all
BIOPROJECTS_TRIPLE = [bp for bp, cond, cov in bioproject_condition_covariate_triples]
CONDITIONS_TRIPLE  = [cond for bp, cond, cov in bioproject_condition_covariate_triples]
COVARIATES_TRIPLE  = [cov for bp, cond, cov in bioproject_condition_covariate_triples]

# Utility for MultiQC input collection
def get_multiqc_input(wildcards):
    bioproject = wildcards.bioproject
    runs = df[df['bioproject'] == bioproject]['run'].tolist()
    inputs = []

    for run in runs:
        inputs += [
            f"results/qc/fastqc_pre/{bioproject}/{run}/{run}_short_fastqc.zip",
            f"logs/cutadapt/{bioproject}/{run}_short_summary.json",
            f"results/qc/fastqc_aft/{bioproject}/{run}/{run}_short_trimmed_fastqc.zip",
            f"results/aligned/{bioproject}/{run}_short.flagstat.txt",
        ]
    inputs += [f"results/counts/{bioproject}/counts.txt"]

    return inputs

