rule deseq2:
    input:
        counts="results/counts/{bioproject}/counts.txt",
        metadata="results/deg/{bioproject}/phenodata.csv"
    output:
        csv="results/deg/{bioproject}/deseq_results.csv",
        filtered="results/deg/{bioproject}/deseq_results_filtered.csv",
        interaction="results/deg/{bioproject}/deseq_results_interaction.csv",
        interaction_filtered="results/deg/{bioproject}/deseq_results_interaction_filtered.csv"
    params:
        padj = lambda wildcards: {"BEAS_2B_short": 0.1, "HEP_G2_short": 0.2}.get(wildcards.bioproject, 0.1),
        logfc=1
    threads: 2
    resources:
        mem_mb=16000
    log:
        "logs/deg/{bioproject}_deseq.log"
    shell:
        """
        Rscript workflow/scripts/deseq2_core.R \
            -c {input.counts} \
            -p {input.metadata} \
            -o {output.csv} \
            -x {output.interaction} \
            --padj {params.padj} \
            --logfc {params.logfc} > {log} 2>&1
        """

