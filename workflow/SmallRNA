rule deplete_contaminants:
    input:
        index=rules.build_contaminant_index.output.index,
        trimmed="results/trimmed/{bioproject}/{run}/{run}_short_trimmed.fq.gz"
    output:
        clean="results/depleted/{bioproject}/{run}_short_clean.fq.gz",
        aligned="results/depleted/{bioproject}/{run}_short_contaminants.sam"
    log:
        "logs/deplete/{bioproject}/{run}_short.log"
    threads: 4
    resources:
        mem_mb=4000
    shell:
        """
        bowtie -v 1 -p {threads} --un >(gzip > {output.clean}) -x {input.index}/contaminants {input.trimmed} > {output.aligned} 2> {log}
        """

rule flagstat_depleted:
