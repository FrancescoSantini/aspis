rule cutadapt:
    input:
        "samples/{bioproject}/{run}/{run}_short.fq.gz"
    output:
        trimmed = "results/trimmed/{bioproject}/{run}/{run}_short_trimmed.fq.gz",
        summary = "logs/cutadapt/{bioproject}/{run}_short_summary.json"
    params:
        adapter = config["cutadapt"]["adapter"],
        minlen = config["cutadapt"]["min_length"],
        maxlen = config["cutadapt"]["max_length"],
        qual = config["cutadapt"]["quality_cutoff"]
    threads: config["resources"]["small"]["threads"]
    resources:
        mem_mb = config["resources"]["small"]["mem_mb"]
    log:
        "logs/cutadapt/{bioproject}/{run}_short.log"
    shell:
        """
        cutadapt \
            -a {params.adapter} \
            --overlap 5 \
            --quality-cutoff {params.qual} \
            -m {params.minlen} -M {params.maxlen} \
            --match-read-wildcards --trim-n --report=full \
            --json {output.summary} \
            -o {output.trimmed} {input} > {log} 2>&1
        """

