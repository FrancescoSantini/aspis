rule fasterq_dump_pe:
    input:
        sra="samples/{bioproject}/{accession}/{accession}.sra"
    output:
        r1="samples/{bioproject}/{accession}/{accession}_1.fastq",
        r2="samples/{bioproject}/{accession}/{accession}_2.fastq"
    threads: config["resources"]["medium"]["threads"]
    resources:
        mem_mb=config["resources"]["medium"]["mem_mb"]
    log:
        "logs/fasterq_dump/{bioproject}/{accession}.log"
    shell:
        """
        fasterq-dump --split-files {input.sra} -O samples/{wildcards.bioproject}/{wildcards.accession}/ \
        > {log} 2>&1
        """
##        """
##        module load autoload profile/bioinf
##        module load autoload sra
##        """

rule fasterq_dump_se:
    input:
        sra="samples/{bioproject}/{accession}/{accession}.sra"
    output:
        fastq="samples/{bioproject}/{accession}/{accession}.fastq"
    params:
        outdir="samples/{bioproject}/{accession}/"
    threads: config["resources"]["medium"]["threads"]
    resources:
        mem_mb=config["resources"]["medium"]["mem_mb"]
    log:
        "logs/fasterq_dump/{bioproject}/{accession}.log"
    shell:
        """
        fasterq-dump {input.sra} -O {params.outdir} > {log} 2>&1
        """
##        """
##        module load autoload profile/bioinf
##        module load autoload sra
##        """

ruleorder: fqzip_pe > fqzip_se

rule fqzip_pe:
    input:
        i1 = "samples/{bioproject}/{accession}/{accession}_1.fastq",
        i2 = "samples/{bioproject}/{accession}/{accession}_2.fastq"
    output:
        o1 = "samples/{bioproject}/{accession}/{accession}_1.fastq.gz",
        o2 = "samples/{bioproject}/{accession}/{accession}_2.fastq.gz"
    threads: config["resources"]["tiny"]["threads"]
    resources:
        mem_mb = config["resources"]["tiny"]["mem_mb"]
    log:
        "logs/fqzip/{bioproject}/{accession}_fqzip_pe.log"
    shell:
        """
        gzip -c {input.i1} > {output.o1}
        gzip -c {input.i2} > {output.o2}
        """

rule fqzip_se:
    input:
        "samples/{bioproject}/{accession}/{accession}.fastq"
    output:
        "samples/{bioproject}/{accession}/{accession}.fastq.gz"
    threads: config["resources"]["tiny"]["threads"]
    resources:
        mem_mb=config["resources"]["tiny"]["mem_mb"]
    log:
        "logs/fqzip/{bioproject}/{accession}_fqzip.log"
    shell:
        """
        gzip -c {input} > {output} 2> {log}
        """

rule fastqc_pre:
    input:
        "samples/{bioproject}/{accession}/{accession}{read}.fastq.gz"
    output:
        html="results/qc/fastqc_pre/{bioproject}/{accession}/{accession}{read}_fastqc.html",
        zip="results/qc/fastqc_pre/{bioproject}/{accession}/{accession}{read}_fastqc.zip" # the suffix _fastqc.zip is necessary for multiqc to find the file. If not using multiqc, you are free to choose an arbitrary filename
    params:
        outdir="results/qc/fastqc_pre/{bioproject}/{accession}"
    threads: config["resources"]["small"]["threads"]
    resources:
        mem_mb=config["resources"]["small"]["mem_mb"]
    log:
        "logs/fastqc_pre/{bioproject}/{accession}{read}.log"
    shell:
        """
        fastqc -o {params.outdir} -f fastq --extract {input} > {log} 2>&1
        """
