        filtered = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/deseq_results_filtered.csv"
    output:
        go = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/GO_enrichment.csv",
        go_dotplot = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/GO_dotplot.pdf",
        kegg = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/KEGG_enrichment.csv",
        kegg_dotplot = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/KEGG_dotplot.pdf",
        reactome = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/Reactome_enrichment.csv",
        reactome_dotplot = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/Reactome_dotplot.pdf",
        summary = "results/deg_tx/{bioproject}/{condition}_vs_control_{covariate}/all_enrichments_summary.csv"
    params:
        padj = config["enrichment"]["padj"],
        logfc = config["enrichment"]["logfc"]
    threads: config["resources"]["medium"]["threads"]
    resources:
        mem_mb = config["resources"]["medium"]["mem_mb"]
    log:
        "logs/deg_tx/{bioproject}/{condition}_vs_control_{covariate}_enrich.log"
    shell:
        """
        Rscript workflow/scripts/enrich_gene_targets.R \
            -i {input.filtered} \
            -o results/deg_tx/{wildcards.bioproject}/{wildcards.condition}_vs_control_{wildcards.covariate} \
            --padj-threshold {params.padj} \
            --logfc-threshold {params.logfc} > {log} 2>&1
        """

