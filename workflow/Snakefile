# Function to check if a sample is coming from SRA
def check_sample(accession, bioproject):
    pattern = r"^(SRR|ERR|DRR)[0-9]+$"
    if re.match(pattern, accession):
        return f"samples/{bioproject}/{accession}/{accession}.sra"

# List of SRA sample paths
sra_samples = [
    check_sample(row['run'], row['bioproject'])
    for _, row in df.iterrows()
    if check_sample(row['run'], row['bioproject']) is not None
]

def get_local_sample(accession, bioproject):
    pattern = r"^(SRR|ERR|DRR)[0-9]+$"
    if not re.match(pattern, accession):
        sample_dir = f"samples/{bioproject}/{accession}"
        if os.path.exists(sample_dir):
        # Check for paired-end files
            paired_files = sorted(glob.glob(f"{sample_dir}/{accession}_[1-2].fastq.gz"))
            if len(paired_files) == 2:
                return ('pe', paired_files)
            
            # Check for single-end file
            single_file = glob.glob(f"{sample_dir}/{accession}.fastq.gz")
            if single_file:
                return ('se', single_file[0])

            # If no matching files found, return None
            return None
    return None

# Initialize separate lists for paired-end and single-end samples
local_samples_pe = []
local_samples_se = []

for _, row in df.iterrows():
    result = get_local_sample(row['run'], row['bioproject'])
    if result is not None:
        sample_type, sample_files = result
        if sample_type == 'pe':
            local_samples_pe.extend(sample_files)  # Add both files for paired-end
        else:
            local_samples_se.append(sample_files)  # Add single file for single-end

## Print the results
#print("Paired-end local samples found:")
#for sample in local_samples_pe:
#    print(sample)

#print("Single-end local samples found:")
#for sample in local_samples_se:
#    print(sample)


#Global lists for output files
all_output_pe = [] + local_samples_pe
all_output_se = [] + local_samples_se


for sra_file in sra_samples:

    # Function to check if a sample is paired-end
    def isPairedSRA(sra_file):
        sra_file = os.path.abspath(sra_file)
        if not os.path.exists(sra_file):
            print(f"File {sra_file} does not exist. Skipping paired-end check.")
            return None  # Return None or handle as needed
        try:
            contents = sp.check_output(["fastq-dump", "-X", "1", "-Z", "--split-spot", sra_file], text=True)
        except sp.CalledProcessError as e:
            raise Exception(f"Error running fastq-dump on {sra_file}: {e}")
    
        if contents.count("\n") == 4:
            return False
        elif contents.count("\n") == 8:
            return True
        else:
            print(f"Unexpected output from fastq-dump on {sra_file}")
            return None  # Handle unexpected output


    # Function to generate expected output files based on paired-end status
    def get_output_files(wildcards):
        sra_file = f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}.sra"
        if isPairedSRA(sra_file):
            return [
                f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}_1.fastq.gz",
                f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}_2.fastq.gz"
            ]
        else:
            return [
                f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}.fastq.gz"
            ]
        

# Populate the output lists based on paired-end status
for sra_file in sra_samples:
    # Extract bioproject and accession from the file path
    parts = sra_file.split('/')
    wildcards = {'bioproject': parts[1], 'accession': parts[2]}
    output_files = get_output_files(wildcards)
    if isPairedSRA(sra_file):
        all_output_pe.extend(output_files)
    else:
        all_output_se.extend(output_files)

