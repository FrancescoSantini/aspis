ruleorder: fqzip_pe > fqzip_se

# Rule to gzip paired-end FASTQ files
rule fqzip_pe:
    input:
        i1 = "samples/{bioproject}/{accession}/{accession}_1.fastq",
        i2 = "samples/{bioproject}/{accession}/{accession}_2.fastq"
    output:
        o1 = "samples/{bioproject}/{accession}/{accession}_1.fastq.gz",
        o2 = "samples/{bioproject}/{accession}/{accession}_2.fastq.gz"
##    threads: config['THREADS']['fqzip']
##    resources:
##        mem_mb=config['RESOURCEMOD']['boost'],
    shell:
        """
        gzip -c {input.i1} > {output.o1}
        gzip -c {input.i2} > {output.o2}
        """

# Rule to gzip single-end FASTQ files
rule fqzip_se:
    input:
        "samples/{bioproject}/{accession}/{accession}.fastq"
    output:
        "samples/{bioproject}/{accession}/{accession}.fastq.gz"
##    threads: config['THREADS']['fqzip']
##    resources:
##        mem_mb=config['RESOURCEMOD']['boost'],
    shell:
        """
        gzip -c {input} > {output}
        """

# Initial fastqc analysis
rule fastqc_pre:
    input:
        "samples/{bioproject}/{accession}/{accession}{read}.fastq.gz"
    output:
        html="results/qc/fastqc_pre/{bioproject}/{accession}/{accession}{read}_fastqc.html",
        zip="results/qc/fastqc_pre/{bioproject}/{accession}/{accession}{read}_fastqc.zip" # the suffix _fastqc.zip is necessary for multiqc to find the file. If not using multiqc, you are free to choose an arbitrary filename
    log:
        "logs/fastqc_pre/{bioproject}/{accession}{read}.log"
##    params: "--quiet"
##    threads: 1
##    resources:
##        mem_mb=10000,
    shell:
        """
        fastqc -o results/qc/fastqc_pre/{wildcards.bioproject}/{wildcards.accession} -f fastq --extract {input} > {log} 2>&1
        """
##        """
##        module load autoload profile/bioinf
##        module load autoload fastqc
##        fastqc -o results/qc/fastqc_pre/{wildcards.bioproject}/{wildcards.accession} -t {threads} -f fastq --extract {input} > {log} 2>&1
##        module purge
##        """

ruleorder: trimmomatic_pe > trimmomatic_se

rule trimmomatic_pe:
    input:
        r1="samples/{bioproject}/{accession}/{accession}_1.fastq.gz",
        r2="samples/{bioproject}/{accession}/{accession}_2.fastq.gz"
    output:
        r1="results/trimmed/{bioproject}/{accession}/{accession}_1_trimmed.fastq.gz",
        r2="results/trimmed/{bioproject}/{accession}/{accession}_2_trimmed.fastq.gz",
        r1_unpaired="results/trimmed/{bioproject}/{accession}/{accession}_1.unpaired.fastq.gz",
        r2_unpaired="results/trimmed/{bioproject}/{accession}/{accession}_2.unpaired.fastq.gz"
    log:
        "logs/trimmomatic/{bioproject}/{accession}_pe.log"
    params:
        trimmer = ["ILLUMINACLIP:TruSeq3-PE.fa:2:30:10", "LEADING:3", "TRAILING:3", "SLIDINGWINDOW:4:15", "MINLEN:36"]
##        **config["params"]["trimmomatic"]["pe"],
##    threads: config['THREADS']['trimmo']
    shell:
        """
        trimmomatic PE -threads {threads} \
        {input.r1} {input.r2} \
        {output.r1} {output.r1_unpaired} \
        {output.r2} {output.r2_unpaired} \
        {params.trimmer} \
        2> {log}
        """

rule trimmomatic_se:
    input:
        "samples/{bioproject}/{accession}/{accession}.fastq.gz"
    output:
        "results/trimmed/{bioproject}/{accession}/{accession}_trimmed.fastq.gz"
    log:
        "logs/trimmomatic/{bioproject}/{accession}_se.log"
    params:
        trimmer = ["ILLUMINACLIP:TruSeq3-SE.fa:2:30:10", "LEADING:3", "TRAILING:3", "SLIDINGWINDOW:4:15", "MINLEN:36"]
##    **config["params"]["trimmomatic"]["pe"],
##    threads: config['THREADS']['trimmo']
    shell:
        """
        trimmomatic SE -threads {threads} \
        {input} \
        {output} \
        {params.trimmer} \
        2> {log}
        """

