rule build_count_matrices_merged:
    input:
        gtfs = lambda wildcards: expand(
            "results/quantified/{bioproject}/{accession}.gtf",
            bioproject=wildcards.bioproject,
            accession=df[df['bioproject'] == wildcards.bioproject]['run']
        ),
        phenodata = "results/deg/{bioproject}/phenodata.csv"
    output:
        gene_counts = "results/deg/{bioproject}/gene_count_matrix.csv",
        gene_metadata = "results/deg/{bioproject}/gene_metadata.csv",
        transcript_counts = "results/deg_tx/{bioproject}/transcript_count_matrix.csv",
        transcript_metadata = "results/deg_tx/{bioproject}/transcript_metadata.csv"
    params:
        gtfs_csv = lambda wildcards, input: ",".join(input.gtfs),
        tmap_path = lambda wildcards: f"results/assembly/{wildcards.bioproject}/gffcompare/{wildcards.bioproject}_stringtie_merged.gtf.tmap",
        known_strict = config["known_codes_strict"],
        known_lenient = config["known_codes_lenient"],
        gene_type_view = config["gene_type_view"]
    threads: config["resources"]["medium"]["threads"]
    resources:
        mem_mb = config["resources"]["xheavy"]["mem_mb"]
    log:
        "logs/counts/{bioproject}.log"
    shell:
        """
        Rscript workflow/scripts/generate_counts_from_gtfs.R \
          --gtfs {params.gtfs_csv} \
          --phenodata {input.phenodata} \
          --gene-count-output {output.gene_counts} \
          --gene-metadata-output {output.gene_metadata} \
          --transcript-count-output {output.transcript_counts} \
          --transcript-metadata-output {output.transcript_metadata} \
          --tmap {params.tmap_path} \
          --known-codes-strict {params.known_strict} \
          --known-codes-lenient {params.known_lenient} \
          --gene-type-view {params.gene_type_view} \
          > {log} 2>&1
        """

rule isoform_switch:
    input:
        transcripts = "results/deg_tx/{bioproject}/transcript_count_matrix.csv",
        phenodata = "results/deg/{bioproject}/phenodata.csv",
        gtf = "results/assembly/{bioproject}/gffcompare/{bioproject}.annotated.clean.gtf"
    output:
        summary = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/isoform_switch_summary.csv",
        qc = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/isoform_switch_qc.pdf",
        rds = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/switch_list.rds",
        consequences = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/switch_consequences_summary.csv",
        expr_debug = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/expression_summary.txt",
        detailed = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/isoform_switch_detailed.csv",
        dif_dist = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/dif_distribution.pdf",
        nt_fasta = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/isoformSwitchAnalyzeR_nt.fasta",
        aa_fasta = "results/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}/isoformSwitchAnalyzeR_AA.fasta"
    params:
        gene_expr_cutoff = config["isoform_switch"]["gene_expression_cutoff"],
        iso_expr_cutoff = config["isoform_switch"]["isoform_expression_cutoff"],
        padj_cutoff = config["isoform_switch"]["padj_cutoff"],
        dIF_cutoff = config["isoform_switch"]["dIF_cutoff"],
        max_genes_to_plot = config["isoform_switch"]["max_genes_to_plot"]
    threads: config["resources"]["xheavy"]["threads"]
    resources:
        mem_mb = config["resources"]["xheavy"]["mem_mb"]
    log:
        "logs/isoform_switches/{bioproject}/{condition}_vs_control_{covariate}.log"
    shell:
        """
        Rscript workflow/scripts/run_isoform_switch_analysis.R \
            --counts {input.transcripts} \
            --phenodata {input.phenodata} \
            --gtf {input.gtf} \
            --outdir results/isoform_switches/{wildcards.bioproject}/{wildcards.condition}_vs_control_{wildcards.covariate} \
            --gene-expr {params.gene_expr_cutoff} \
            --isoform-expr {params.iso_expr_cutoff} \
            --condition {wildcards.condition} \
            --covariate {wildcards.covariate} \
            --padj {params.padj_cutoff} \
            --dIF {params.dIF_cutoff} \
            --max_genes {params.max_genes_to_plot} > {log} 2>&1
        """

