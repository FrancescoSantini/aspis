    basefqcaft = file.replace("samples/", "results/qc/fastqc_aft/").replace(".fastq.gz", "")
    fastqc_output_pe.extend([f"{basefqcaft}_trimmed_fastqc.html", f"{basefqcaft}_trimmed_fastqc.zip"])

for file in all_output_se:
