# Write full phenodata (unfiltered by time or condition)
os.makedirs("results/deg", exist_ok=True)
for bp in BIOPROJECTS:
    os.makedirs(f"results/deg/{bp}", exist_ok=True)
    df_filtered = df[df.bioproject == bp].copy()
    phenodata = df_filtered[["sample_name", "biosample", "condition"] +
                            [col for col in df.columns if col.startswith("covariate")]] \
                .set_index("sample_name") \
                .fillna("NA")
    phenodata.to_csv(f"results/deg/{bp}/phenodata.csv", sep=",")


# Create triple list for DESeq2 contrasts (bioproject, condition != control, covariate1)
bioproject_condition_covariate_triples = []
for bp in BIOPROJECTS:
    subdf = df[df["bioproject"] == bp]
    conditions = subdf["condition"].dropna().unique().tolist()
    conditions = [c for c in conditions if c != "control"]
    covariates = subdf["covariate1"].dropna().unique().tolist()

    for condition in conditions:
        for covariate in covariates:
            bioproject_condition_covariate_triples.append((bp, condition, covariate))

# Define zipped components for use in expand() in rule all
BIOPROJECTS_TRIPLE = [bp for bp, cond, cov in bioproject_condition_covariate_triples]
CONDITIONS_TRIPLE  = [cond for bp, cond, cov in bioproject_condition_covariate_triples]
COVARIATES_TRIPLE  = [cov for bp, cond, cov in bioproject_condition_covariate_triples]


