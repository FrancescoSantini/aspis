##        """

rule hisat2_index:
    input:
        fasta = config["reference_genome"]
    output:
        folder = directory("genome/hisat2_index"),
        index = "genome/hisat2_index/genome.1.ht2"
    log:
        "logs/hisat2_index/index.log"
##    params:
##        prefix = "index_{genome}/"
    threads: 4
##    resources:
##        mem_mb=config['RESOURCEMOD']['high'],
    shell:
        """
        mkdir -p {output.folder}
        hisat2-build -p {threads} {input.fasta} {output.folder}/genome
        """

rule hisat2_align:
    input:
        index = "genome/hisat2_index/genome.1.ht2",
        reads = lambda wildcards: (
            [f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_{read}_trimmed.fastq.gz" for read in [1, 2]]
            if f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_1_trimmed.fastq.gz" in trimmed_output_pe
            else f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_trimmed.fastq.gz"
        )
    output:
        bam = "results/aligned/{bioproject}/{accession}.bam"
    log:
        "logs/hisat2/{bioproject}/{accession}.log"
    threads: 8
    params:
        idx="genome/hisat2_index/genome"
##    resources:
##        mem_mb=config['RESOURCEMOD']['high'],
##        time=config['RESOURCEMOD']['moretime'],
#    run:
#        if isinstance(input.reads, list):
            #Paired-end
#            shell("""
#                hisat2 -x {params.idx} -1 {input.reads[0]} -2 {input.reads[1]} -p {threads} | \
#                samtools view -bS - > {output.bam}
#            """)
#        else:
#            shell("""
#                hisat2 -x {params.idx} -U {input.reads} -p {threads} | \
#                samtools view -bS - > {output.bam}
#            """)
    shell:
        """
        if [ -f {input.reads[1]} ]; then
            hisat2 -x {params.idx} -1 {input.reads[0]} -2 {input.reads[1]} -p {threads} |
            samtools view -bS - > {output.bam}
        else
            hisat2 -x {params.idx} -U {input.reads} -p {threads} |
            samtools view -bS - > {output.bam}
        fi 2> {log}
        """

rule samtools_sort:
    input:
        "results/aligned/{bioproject}/{accession}.bam"
    output:
        "results/sorted/{bioproject}/{accession}_sorted.bam"
##    threads: config['THREADS']['samsort']
##    resources:
##        mem_mb=config['RESOURCEMOD']['high'],
    shell:
        """
        samtools sort {input} -o {output}
        """

rule stringtie:
    input:
        bam = "results/sorted/{bioproject}/{accession}_sorted.bam",
        annotation = config["reference_annotation"]
    output:
        "results/assembly/{bioproject}/{accession}.gtf"
    threads: 4
    shell:
        """
        stringtie {input.bam} \
        -G {input.annotation} \
        -o {output} \
        -e
        """
##        """
##        module load autoload profile/bioinf && \
##        module load stringtie && \
##        module load illumina_genome_Homo_sapiens/hg38 && \
##        stringtie {input} \
##        -G $ANNOTATION/Genes/genes.gtf \
##        -o {output} \
##        -e
##        """

rule merge:
    input:
        gtfs = get_gtf_files,
        annotation = config["reference_annotation"]
    output:
        "results/assembly/{bioproject}/{bioproject}_stringtie_merged.gtf"
    log:
        "logs/assembly/{bioproject}/{bioproject}_stringtie_merged.log"
    threads: 4
    shell:
        """
        stringtie --merge \
        -G {input.annotation} \
        -o {output} \
        {input.gtfs}
        """
##        """
##        module load autoload profile/bioinf && \
