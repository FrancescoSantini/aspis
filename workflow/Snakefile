rule preprep:
    input:
        i1 = "config/sample_sheet.csv",
        i2 = "results/assembly/{bioproject}/{bioproject}_stringtie_merged.gtf"
    output:
        o1 = "results/assembly/{bioproject}/{bioproject}_sample_lst.txt",
        o2 = "results/deg/{bioproject}/phenodata.csv"
    shell:
        """
        python3 workflow/scripts/preprep.py {input.i1} {input.i2} {output.o1} {output.o2}
        """
