#Global lists for output files
all_output_pe = [] + local_samples_pe
all_output_se = [] + local_samples_se

def isPairedSRA(sra_file):
    """
    Determine if an SRA file is paired-end using fastq-dump.
    Suppresses verbose output and provides robust error handling.
    """
    sra_file = os.path.abspath(sra_file)
    if not os.path.exists(sra_file):
        print(f"File {sra_file} does not exist. Skipping paired-end check.")
        return None  # Handle as needed (e.g., log or skip)

    try:
        # Suppress verbose output from fastq-dump
        contents = sp.check_output(
            ["fastq-dump", "-X", "1", "-Z", "--split-spot", sra_file],
            text=True,
            stderr=sp.DEVNULL  # Suppresses stderr
        )
    except sp.CalledProcessError as e:
        print(f"Error running fastq-dump on {sra_file}: {e}")
        return None  # Log or decide how to handle the error
    
    # Determine paired-end status based on line count
    line_count = contents.count("\n")
    if line_count == 4:
        return False  # Single-end
    elif line_count == 8:
        return True  # Paired-end
    else:
        print(f"Unexpected output from fastq-dump on {sra_file}. Line count: {line_count}")
        return None  # Handle unexpected output gracefully

# Precompute paired-end status
print("Evaluating paired-end status for all SRA files. Please wait...")  # Notify user about progress
paired_status = {sra_file: isPairedSRA(sra_file) for sra_file in sra_samples}

def get_output_files(wildcards):
    """
    Generate expected output files based on paired-end status.
    """
    sra_file = f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}.sra"
    paired = paired_status.get(sra_file)

    if paired is None:
        raise ValueError(f"Cannot determine paired-end status for {sra_file}")

    if paired:
        return [
            f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}_1.fastq.gz",
            f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}_2.fastq.gz"
        ]
    else:
        return [
            f"samples/{wildcards['bioproject']}/{wildcards['accession']}/{wildcards['accession']}.fastq.gz"
        ]
        

# Populate the output lists based on paired-end status
for sra_file in sra_samples:
    # Extract bioproject and accession from the file path
    parts = sra_file.split('/')
    wildcards = {'bioproject': parts[1], 'accession': parts[2]}
    output_files = get_output_files(wildcards)
    if paired_status[sra_file]:
        all_output_pe.extend(output_files)
    else:
        all_output_se.extend(output_files)

