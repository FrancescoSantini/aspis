def get_gtf_files(wildcards):
    gtf_files = expand("results/assembly/{bioproject}/{accession}.gtf",
                       bioproject=wildcards.bioproject,
                       accession=df[df['bioproject'] == wildcards.bioproject]['run'])
 #   print(f"GTF files for bioproject {wildcards.bioproject}:")
 #   print(gtf_files)
    return gtf_files


