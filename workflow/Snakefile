rule hisat2_index:
    input:
        fasta = config["reference_genome"]
    output:
        folder = directory("genome/hisat2_index"),
        index = "genome/hisat2_index/genome.1.ht2"
    threads: config["resources"]["medium"]["threads"]
    resources:
        mem_mb = config["resources"]["medium"]["mem_mb"]
    log:
        "logs/hisat2_index/index.log"
    shell:
        """
        mkdir -p {output.folder}
        hisat2-build -p {threads} {input.fasta} {output.folder}/genome
        """

rule hisat2_align:
    input:
        index = "genome/hisat2_index/genome.1.ht2",
        reads = lambda wildcards: (
            [f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_{read}_trimmed.fastq.gz" for read in [1, 2]]
            if f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_1_trimmed.fastq.gz" in trimmed_output_pe
            else f"results/trimmed/{wildcards.bioproject}/{wildcards.accession}/{wildcards.accession}_trimmed.fastq.gz"
        )
    output:
        bam = "results/aligned/{bioproject}/{accession}.bam"
    params:
        idx = "genome/hisat2_index/genome"
    threads:
        config["resources"]["medium"]["threads"]
    resources:
        mem_mb = config["resources"]["medium"]["mem_mb"]
    log:
        "logs/hisat2/{bioproject}/{accession}.log"
    shell:
        """
        if [ -f {input.reads[1]} ]; then
            hisat2 -x {params.idx} -1 {input.reads[0]} -2 {input.reads[1]} -p {threads} |
            samtools view -bS - > {output.bam}
        else
            hisat2 -x {params.idx} -U {input.reads} -p {threads} |
            samtools view -bS - > {output.bam}
        fi 2> {log}
        """

rule samtools_sort:
    input:
        "results/aligned/{bioproject}/{accession}.bam"
