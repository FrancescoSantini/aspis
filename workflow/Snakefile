rule gffcompare_annotate:
    input:
        merged_gtf = "results/assembly/{bioproject}/{bioproject}_stringtie_merged.gtf",
        reference = config["reference_annotation"]
    output:
        annotated_gtf_raw = "results/assembly/{bioproject}/gffcompare/{bioproject}.annotated.gtf",
        tracking = "results/assembly/{bioproject}/gffcompare/{bioproject}.tracking"
    threads: config["resources"]["tiny"]["threads"]
    resources:
        mem_mb = config["resources"]["tiny"]["mem_mb"]
    log:
        "logs/assembly/{bioproject}/{bioproject}_gffcompare.log"
    shell:
        """
        gffcompare \
          -r {input.reference} \
          -o results/assembly/{wildcards.bioproject}/gffcompare/{wildcards.bioproject} \
          {input.merged_gtf} > {log} 2>&1
        mv results/assembly/{wildcards.bioproject}/{wildcards.bioproject}.{wildcards.bioproject}_stringtie_merged.gtf.tmap \
           results/assembly/{wildcards.bioproject}/gffcompare/{wildcards.bioproject}_stringtie_merged.gtf.tmap || true
        mv results/assembly/{wildcards.bioproject}/{wildcards.bioproject}.{wildcards.bioproject}_stringtie_merged.gtf.refmap \
           results/assembly/{wildcards.bioproject}/gffcompare/{wildcards.bioproject}_stringtie_merged.gtf.refmap || true
        """

rule gffcompare_clean_annotated:
