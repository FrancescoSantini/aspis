def get_multiqc_input(wildcards):
    """
    Gather all required input files for MultiQC for the specified bioproject.
    Includes FastQC files, trimmed FASTQ files, and sorted BAM files, 
    dynamically handling paired-end and single-end files.
    """
    bioproject = wildcards.bioproject
    multiqc_input = []

    # Process each run in the bioproject
    accessions = df[df['bioproject'] == bioproject]['run'].tolist()

    for accession in accessions:
        if any(bioproject.startswith(prefix) for prefix in ["PRJNA", "PRJEB", "SRP", "PRJDB"]):
            # Handle SRA-derived samples
            sra_file = f"samples/{bioproject}/{accession}/{accession}.sra"
            paired = paired_status.get(sra_file)

            if paired is None:
                raise ValueError(f"Paired-end status for {sra_file} could not be determined")

            # Add FastQC outputs and trimmed FASTQ files
            if paired:
                multiqc_input += [
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_1_fastqc.zip",
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_2_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_1_trimmed_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_2_trimmed_fastqc.zip",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_1_trimmed.fastq.gz",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_2_trimmed.fastq.gz",
                ]
            else:
                multiqc_input += [
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_trimmed_fastqc.zip",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_trimmed.fastq.gz",
                ]

            # Add sorted BAM files
            multiqc_input += [
                f"results/sorted/{bioproject}/{accession}_sorted.bam",
                f"results/qc/flagstat/{bioproject}/{accession}_sorted.flagstat.txt"
            ]
        else:
            # Handle user-provided personal/local samples
            if f"samples/{bioproject}/{accession}/{accession}_1.fastq.gz" in local_samples_pe:
                # Paired-end personal/local samples
                multiqc_input += [
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_1_fastqc.zip",
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_2_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_1_trimmed_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_2_trimmed_fastqc.zip",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_1_trimmed.fastq.gz",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_2_trimmed.fastq.gz",
                ]
            else:
                # Single-end personal/local samples
                multiqc_input += [
                    f"results/qc/fastqc_pre/{bioproject}/{accession}/{accession}_fastqc.zip",
                    f"results/qc/fastqc_aft/{bioproject}/{accession}/{accession}_trimmed_fastqc.zip",
                    f"results/trimmed/{bioproject}/{accession}/{accession}_trimmed.fastq.gz",
                ]

            # Add sorted BAM files
            multiqc_input += [
                f"results/sorted/{bioproject}/{accession}_sorted.bam",
                f"results/qc/flagstat/{bioproject}/{accession}_sorted.flagstat.txt"
            ]

    return multiqc_input


